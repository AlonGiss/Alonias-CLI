<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/ng_card_red_black">

    <LinearLayout
        android:id="@+id/singleGameCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:background="@drawable/bg_card_red"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintWidth_percent="0.80">

        <TextView
            android:id="@+id/tvTimerSingle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="00:00"
            android:textSize="18sp"
            android:textColor="#FFB4B4"
            android:textStyle="bold"
            android:gravity="center_horizontal"
            android:paddingBottom="8dp" />

        <TextView
            android:id="@+id/tvScoreSingle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Score: 0"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:gravity="center_horizontal"
            android:paddingBottom="16dp" />

        <TextView
            android:id="@+id/tvWordSingle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="———"
            android:textSize="32sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingTop="24dp"
            android:paddingBottom="24dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCorrect"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="@string/correct"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:background="@drawable/bg_button_red"
            app:backgroundTint="@null"
            app:rippleColor="@android:color/transparent"
            android:layout_marginBottom="12dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSkipSingle"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="@string/skip"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:background="@drawable/bg_button_red"
            app:backgroundTint="@null"
            app:rippleColor="@android:color/transparent"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>

