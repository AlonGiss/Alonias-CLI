<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/ng_card_red_black">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/gameOverCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="24dp"
            android:orientation="vertical"
            android:padding="24dp"
            android:background="@drawable/bg_card_red"
            android:gravity="center_horizontal">

            <!-- TITLE -->
            <TextView
                android:id="@+id/tvGameOverTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/end_game"
                android:textSize="30sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:gravity="center"
                android:letterSpacing="0.15"
                android:fontFamily="@font/planet_jumbo"
                android:paddingBottom="12dp"
                android:shadowColor="@color/white"
                android:shadowDx="0"
                android:shadowDy="0"
                android:shadowRadius="40" />

            <!-- RESULT -->
            <TextView
                android:id="@+id/tvResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="15sp"
                android:textColor="#FFB4B4"
                android:textStyle="bold"
                android:gravity="center"
                android:paddingBottom="16dp" />

            <!-- REASON -->
            <TextView
                android:id="@+id/tvReason"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="14sp"
                android:textColor="#FF8A80"
                android:gravity="center"
                android:paddingBottom="16dp"
                android:visibility="gone" />

            <!-- SCORES LABEL -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/results"
                android:textColor="#FFB4B4"
                android:textSize="13sp"
                android:textStyle="bold"
                android:gravity="center"
                android:paddingBottom="8dp" />

            <!-- SCORES -->
            <LinearLayout
                android:id="@+id/scoreRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingBottom="16dp">

                <TextView
                    android:id="@+id/tvScoreA"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/team_a"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:gravity="start" />

                <TextView
                    android:id="@+id/tvScoreB"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/team_b"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:gravity="end" />
            </LinearLayout>

            <!-- PLAYERS LABEL -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/players"
                android:textColor="#FFB4B4"
                android:textSize="13sp"
                android:textStyle="bold"
                android:paddingBottom="8dp" />

            <TextView
                android:id="@+id/tvTeam0Players"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_input"
                android:text="@string/team_a"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:padding="12dp"
                android:layout_marginBottom="10dp" />

            <TextView
                android:id="@+id/tvTeam1Players"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_input"
                android:text="@string/team_b"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:padding="12dp"
                android:layout_marginBottom="18dp" />

            <!-- BUTTONS -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRematch"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="@string/play_again"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_button_red"
                app:backgroundTint="@null"
                app:rippleColor="@android:color/transparent" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLeave"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="@string/back_to_menu"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:background="@drawable/bg_button_red"
                app:backgroundTint="@null"
                app:rippleColor="@android:color/transparent" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>